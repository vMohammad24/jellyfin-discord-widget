{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                discord_id,\n                discord_access_token,\n                discord_refresh_token,\n                jellyfin_url,\n                jellyfin_user_id,\n                jellyfin_access_token,\n                last_active_at\n            FROM users\n            WHERE\n                ($1::bigint IS NULL OR discord_id::bigint > $1)\n                AND (\n                    -- Poll active users (active in the last 24 hours) every cycle\n                    last_active_at > NOW() - INTERVAL '24 hours'\n                    -- Poll dormant users only once an hour\n                    OR updated_at <= NOW() - INTERVAL '1 hour'\n                )\n            ORDER BY discord_id::bigint\n            LIMIT $2\n            ",
